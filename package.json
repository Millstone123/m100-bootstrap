{
  "name": "m100-bootstrap",
  "version": "1.0.0",
  "description": "M100 Bootstrap Installer - Platform-aware installation of M100 development tools",
  "scripts": {
    "preinstall": "bash ./scripts/m100-preinstall.sh",
    "install": "bash ./scripts/m100-install.sh",
    "presetup": "bash ./scripts/m100-presetup.sh",
    "setup": "npm run setup:fetch && npm run setup:verify",
    "setup:fetch": "bash ./scripts/m100-setup-fetch.sh",
    "setup:verify": "bash ./scripts/m100-setup-verify.sh",
    "postsetup": "bash ./scripts/m100-postsetup.sh",
    "verify": "bash ./scripts/m100-verify.sh",
    "configure": "bash ./scripts/m100-configure.sh",
    "check": "bash ./scripts/m100-check.sh",
    "export": "bash ./scripts/m100-export.sh"
  },
  "keywords": [
    "m100",
    "bootstrap",
    "installer",
    "cli",
    "tools"
  ],
  "author": "M100 Platform Team",
  "license": "MIT"
}
